# SAP S/4HANA Connection
S4H_BASE_URL=https://YOUR_HOST:44300
S4H_CLIENT=YOUR_CLIENT
SAP_USER=YOUR_USER
SAP_PASSWORD=YOUR_PASSWORD

# Set to true for on-premise systems with self-signed certificates
SAP_INSECURE=true

# MCP Transport — stdio (Phase 1 local) | sse (Phase 2 BTP CF)
MCP_TRANSPORT=stdio
